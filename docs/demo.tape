# Record the Trove demo GIF:  vhs docs/demo.tape  ->  docs/demo.gif
# CI-safe: browses, searches, and selects — it never starts a real download.
Output docs/demo.gif

Set FontSize 16
Set Width 1200
Set Height 720
Set Padding 14
Set Theme "Catppuccin Mocha"

Type "trove" Enter
Sleep 6s
Type "/"
Type "tearaway"
Sleep 1500ms
Enter
Sleep 1s
Space
Sleep 700ms
Down
Sleep 400ms
Space
Sleep 1200ms
Type "q"
Sleep 1s
