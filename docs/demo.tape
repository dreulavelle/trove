# Record the Trove demo GIF:  vhs docs/demo.tape  ->  docs/demo.gif
Output docs/demo.gif

Set FontSize 16
Set Width 1200
Set Height 720
Set Padding 14
Set Theme "Catppuccin Mocha"

Type "uv run trove" Enter
Sleep 5s
Type "/"
Type "tearaway"
Sleep 1500ms
Enter
Sleep 700ms
Space
Sleep 900ms
Type "d"
Sleep 5s
Type "q"
Sleep 1s
